{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/v1", "destination": "/climb", "permanent": false },
    { "source": "/v2", "destination": "/filmstrip", "permanent": false },
    { "source": "/v3", "destination": "/head-to-head", "permanent": false },
    { "source": "/v4", "destination": "/runbooks", "permanent": false }
  ]
}
